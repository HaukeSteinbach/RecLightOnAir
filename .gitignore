OnAirLinkFirmware/sdkconfig.old
OnAirLinkFirmware/managed_components/
OnAirLinkFirmware/dependencies.lock
OnAirLinkFirmware/dist/

# Arduino build output for the older OnAirFirmware sketch
OnAirFirmware/build/

# Windows installer build output
/installer/windows/build/
/installer/windows/*.exe
